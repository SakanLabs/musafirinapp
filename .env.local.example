# Database Config (Matches docker-compose.local.yml)
DATABASE_URL=postgres://postgres:password@localhost:5433/musdb

# Auth Config
BETTER_AUTH_SECRET=local-development-secret-key-123
BETTER_AUTH_URL=http://localhost:3000
BASE_URL=http://localhost:5173

# MinIO Local Storage Config
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_USE_SSL=false
MINIO_BUCKET_NAME=musafirin-assets
MINIO_REGION=ap-southeast-1
MINIO_BASE_URL=http://localhost:9000

# Optional: Google Auth (Leave empty if not using in local)
GOOGLE_CLIENT_ID=mock
GOOGLE_CLIENT_SECRET=mock

# CORS Origins (Important for local dev to communicate between Vite and Bun)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000
