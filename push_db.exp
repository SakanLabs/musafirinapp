#!/usr/bin/expect -f
set timeout -1
spawn bun run dev:db:push
expect {
    -re ".*table created or renamed from another table.*" {
        send "\r"
        exp_continue
    }
    "Do you still want to push changes?" {
        sleep 1
        send "\033\[B"
        sleep 1
        send "\r"
        exp_continue
    }
    eof
}
